}

function winstart () {
  virsh start win11
}

function winstop () {
  virsh shutdown win11
}

function publickey () {
  cat ~/.ssh/id_ed25519.pub | xclip -selection clipboard
}

function fixit () {
  killall cairo-dock
  rm /home/marcelo/.config/cairo-dock -r
  cp /home/marcelo/.config/cairo-dock.old /home/marcelo/.config/cairo-dock -r
  nohup cairo-dock &
}
